{
  "name": "guy-code",
  "productName": "Guy Code",
  "private": false,
  "version": "0.1.18",
  "description": "Cross-platform Claude Code-compatible desktop app",
  "author": {
    "name": "Jason Arnold",
    "email": "jasonar81@users.noreply.github.com"
  },
  "homepage": "https://github.com/jasonar81/guy-code",
  "repository": {
    "type": "git",
    "url": "https://github.com/jasonar81/guy-code.git"
  },
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "clean": "node -e \"const{rmSync}=require('fs');for(const d of ['dist','dist-electron']){try{rmSync(d,{recursive:true,force:true})}catch{}}\"",
    "build": "npm run clean && tsc -p tsconfig.electron.json && tsc -p tsconfig.json && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "release": "npm run build && electron-builder --publish always"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "electron-log": "^5.2.4",
    "electron-updater": "^6.8.3",
    "fflate": "^0.8.3",
    "jsdom": "^29.1.1",
    "lucide-react": "^0.468.0",
    "playwright-core": "^1.60.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-virtuoso": "^4.18.7",
    "remark-gfm": "^4.0.1",
    "sql.js": "^1.12.0",
    "tailwind-merge": "^2.5.5",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.16",
    "@types/react-dom": "^18.3.5",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.7",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "happy-dom": "^20.9.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.1.7"
  },
  "build": {
    "afterPack": "build/afterPack.js",
    "appId": "io.github.jasonar81.guycode",
    "productName": "Guy Code",
    "copyright": "Copyright © 2026 Jason Arnold",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json",
      "!**/*.map",
      "!**/*.d.ts"
    ],
    "extraResources": [
      {
        "from": "chrome-extension",
        "to": "chrome-extension",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/sql.js/dist/sql-wasm.wasm"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "jasonar81",
        "repo": "guy-code"
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null,
      "icon": "build/icon.icns"
    },
    "dmg": {
      "writeUpdateInfo": true,
      "sign": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Guy Code",
      "uninstallDisplayName": "Guy Code"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development",
      "icon": "build/icon.png"
    }
  }
}
